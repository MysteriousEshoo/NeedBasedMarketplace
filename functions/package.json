{
  "name": "needhub-fcm-functions",
  "description": "Firebase Cloud Functions to send FCM push notifications when a notification is written to Realtime Database",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "18"
  },
  "main": "index.js",
  "dependencies": {
    "firebase-admin": "^11.11.0",
    "firebase-functions": "^4.9.0"
  },
  "private": true
}
