rules_version = '2';

// NeedBase storage rules — NOT YET DEPLOYED.
// studyplanner1367's default bucket is shared with other apps; deploying this
// file REPLACES the bucket's current rules, which cannot be read via the CLI.
// Confirm in the console what the other apps need before deploying.
service firebase.storage {
  match /b/{bucket}/o {
    // Chat media: voice notes, images, videos, documents.
    // Channel ids embed both participant uids, so writers must be a participant.
    match /chats/{needId}/{channelId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && channelId.matches('.*' + request.auth.uid + '.*')
                   && request.resource.size < 25 * 1024 * 1024;
    }

    // Profile pictures.
    match /profile_images/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
